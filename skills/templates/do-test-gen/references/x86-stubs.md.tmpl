# x86 Stub Headers — ARM/CMSIS/MCU Replacement

These stubs replace ARM-specific headers for x86 host compilation.
Place in `tests/stubs/` with subdirectories matching the original include paths.

## stubs/CMSIS/arm_math.h

Replaces CMSIS DSP Library header. Provides `float32_t`, `arm_status`, and math function stubs.

```c
/* arm_math.h - x86 test stub
 * Provides type definitions and minimal API stubs from CMSIS DSP Library.
 */
#ifndef _ARM_MATH_H
#define _ARM_MATH_H

#include <math.h>
#include <stdint.h>
#include <string.h>

#ifdef __cplusplus
extern "C" {
#endif

/* Error status */
typedef enum {
	ARM_MATH_SUCCESS = 0,
	ARM_MATH_ARGUMENT_ERROR = -1,
	ARM_MATH_LENGTH_ERROR = -2,
	ARM_MATH_SIZE_MISMATCH = -3,
	ARM_MATH_NANINF = -4,
	ARM_MATH_SINGULAR = -5,
	ARM_MATH_TEST_FAILURE = -6
} arm_status;

/* Fractional data types */
typedef int8_t q7_t;
typedef int16_t q15_t;
typedef int32_t q31_t;
typedef int64_t q63_t;

/* Floating-point types */
typedef float float32_t;
typedef double float64_t;

/* Constants */
#ifndef PI
#define PI 3.14159265358979F
#endif

/* Alignment (no-op on x86) */
#define ALIGN4

/* clip functions */
static inline q31_t clip_q63_to_q31(q63_t x) {
	return ((q31_t)(x >> 32) != ((q31_t)x >> 31))
		? ((0x7FFFFFFF ^ ((q31_t)(x >> 63))))
		: (q31_t)x;
}

static inline q15_t clip_q31_to_q15(q31_t x) {
	return ((q31_t)(x >> 16) != ((q31_t)x >> 15))
		? ((0x7FFF ^ ((q15_t)(x >> 31))))
		: (q15_t)x;
}

static inline q7_t clip_q31_to_q7(q31_t x) {
	return ((q31_t)(x >> 8) != ((q31_t)x >> 7))
		? ((0x7F ^ ((q7_t)(x >> 31))))
		: (q7_t)x;
}

/* Trig function stubs → standard math */
static inline float32_t arm_sin_f32(float32_t x) { return sinf(x); }
static inline float32_t arm_cos_f32(float32_t x) { return cosf(x); }

/* arm_sqrt_f32 stub */
static inline arm_status arm_sqrt_f32(float32_t in, float32_t* pOut) {
	if (in >= 0.0F) {
		*pOut = sqrtf(in);
		return ARM_MATH_SUCCESS;
	}
	*pOut = 0.0F;
	return ARM_MATH_ARGUMENT_ERROR;
}

#ifdef __cplusplus
}
#endif

#endif /* _ARM_MATH_H */
```

## stubs/CMSIS/core_cm4.h

Replaces {{core}} core header. Stubs intrinsics as no-ops or pure C implementations.

```c
/* core_cm4.h - x86 test stub */
#ifndef __CORE_CM4_H_GENERIC
#define __CORE_CM4_H_GENERIC

#include <stdint.h>

#ifdef __cplusplus
extern "C" {
#endif

/* Compiler-agnostic defines */
#ifndef __STATIC_INLINE
#define __STATIC_INLINE static inline
#endif

#ifndef __ASM
#define __ASM
#endif

#ifndef __INLINE
#define __INLINE inline
#endif

/* Core register access stubs (no-op) */
static inline uint32_t __get_PRIMASK(void) { return 0; }
static inline void __set_PRIMASK(uint32_t primask) { (void)primask; }
static inline uint32_t __get_BASEPRI(void) { return 0; }
static inline void __set_BASEPRI(uint32_t basepri) { (void)basepri; }
static inline uint32_t __get_xPSR(void) { return 0; }

/* CLZ instruction */
static inline uint8_t __CLZ(uint32_t value) {
	uint8_t count = 0;
	if (value == 0) return 32;
	while ((value & 0x80000000U) == 0) {
		value <<= 1;
		count++;
	}
	return count;
}

/* Reverse bit order */
static inline uint32_t __RBIT(uint32_t value) {
	uint32_t result = 0;
	for (int i = 0; i < 32; i++) {
		result = (result << 1) | (value & 1);
		value >>= 1;
	}
	return result;
}

/* Saturation */
static inline uint32_t __SSAT(int32_t val, uint32_t sat) {
	int32_t max = (1 << (sat - 1)) - 1;
	int32_t min = -(1 << (sat - 1));
	if (val > max) return (uint32_t)max;
	if (val < min) return (uint32_t)min;
	return (uint32_t)val;
}

static inline uint32_t __USAT(int32_t val, uint32_t sat) {
	uint32_t max = (1U << sat) - 1;
	if (val < 0) return 0;
	if ((uint32_t)val > max) return max;
	return (uint32_t)val;
}

/* Barrier stubs (no-op) */
static inline void __DSB(void) {}
static inline void __ISB(void) {}
static inline void __DMB(void) {}
static inline void __NOP(void) {}
static inline void __WFI(void) {}
static inline void __WFE(void) {}

#ifdef __cplusplus
}
#endif

#endif /* __CORE_CM4_H_GENERIC */
```

