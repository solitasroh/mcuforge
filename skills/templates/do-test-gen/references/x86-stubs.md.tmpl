## stubs/mcu/define.h

Replaces the main project `define.h`. Converts all ARM intrinsics and inline ASM to no-ops.

```c
/* define.h - x86 test stub
 * Strips ARM intrinsics, inline asm, and MCU register access.
 * Preserves macros/types used by application logic.
 */
#ifndef __DEFINE_H__
#define __DEFINE_H__

#include <stdint.h>

#include "arm_math.h"
#include "data_types.h"

/* Clock variables */
extern unsigned long long __system_clock;
extern unsigned long long __bus_clock;
extern unsigned long long __sec_tick;
extern unsigned long long __msec_tick;
extern unsigned long long __usec_tick;

#define SET_CLOCK_TO_COMPONENTS {}
#define SET_CLOCK_TO_COMPONENTS_BY_CONFIG(config_number) {}
#define SET_CLOCK_TO_COMPONENTS_DIRECTLY(system_clock, bus_clock) {}

#define SYSTEM_CLOCK __system_clock
#define BUS_CLOCK __bus_clock
#define SEC_TICK __sec_tick
#define MSEC_TICK __msec_tick
#define USEC_TICK __usec_tick

/* Interrupt control (no-op) */
#define ENABLE_INTERRUPTS
#define DISABLE_INTERRUPTS
#define ENABLE_FAULT_INTERRUPTS
#define DISABLE_FAULT_INTERRUPTS

/* Critical section (no-op) */
#define CRITICAL_SECTION_START {
#define CRITICAL_SECTION_END }

/* NVIC (no-op) */
#define irq_num(irq_number) (int16_t)((irq_number) - 16)
#define ipr_value(irq_number) (uint16_t)(irq_num(irq_number) >> 5)
#define ipr_shift(irq_number) (uint16_t)(irq_num(irq_number) & 0x1F)

#define nvic_enable(irq_number)
#define nvic_disable(irq_number)
#define nvic_get_pending_irq(irq_number) 0
#define nvic_set_pending_irq(irq_number)
#define nvic_clear_pending_irq(irq_number)
#define nvic_set_priority(irq_number, priority)
#define nvic_get_priority(irq_number) 0
#define nvic_set_priority_and_enable(irq_number, priority)

/* ISR declaration (no-op) */
#if !defined(PE_ISR)
#define PE_ISR(ISR_name) void ISR_name(void)
#endif

#define INTERRUPT_CALL(vector, callback, arg) \
	PE_ISR(vector) { callback(arg); }

/* Thread level check (no-op) */
#define IS_HIGHER_LEVEL(level) 0
#define THREAD_LEVEL_CHECK 0

/* Protection (no-op) */
#define PRIORITY_LEVEL_BITS 4
#define PRIORITY_LEVEL_SHIFT (8 - PRIORITY_LEVEL_BITS)

#define protect_start(level) {
#define protect_level(level)
#define unprotect_level(level)
#define unprotect }
#define protect_end }
#define protect_level_noguard(level)

#define PROTECT_LEVEL_CHANGE_BARRIER

#define priority_shift(priority) (unsigned char)((unsigned char)(priority) << PRIORITY_LEVEL_SHIFT)

#define try_until_success(job, retry_number, recover) ({ int32_t error = job; error; })

#define UNUSED(x) ((void)(x))

#ifdef __GNUC__
#define UNUSED_PARAM __attribute__((unused))
#else
#define UNUSED_PARAM
#endif

#endif /* __DEFINE_H__ */
```

## Adding New Stubs

When a module includes a new ARM-specific header not yet stubbed:
1. Check which types/macros/functions the application code actually uses
2. Create a minimal stub providing only those definitions
3. Place in the appropriate subdirectory (`stubs/CMSIS/` or `stubs/mcu/`)
4. Ensure the include guard matches the original header

Do NOT copy the entire original header — only stub what is actually referenced.
